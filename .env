# ==========================================
# 餐厅预订 Agent - 环境配置
# ==========================================

# ========== LLM API Keys ==========

# Anthropic Claude API Key
# 获取地址: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# DeepSeek API Key
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# HuggingFace Token
# 获取地址: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=

# ========== Ollama 配置 ==========

# Ollama 本地服务地址
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama2-chinese

# ========== API 服务器配置 ==========

# API 服务器地址
API_HOST=127.0.0.1
API_PORT=8001

# API 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ========== 数据库配置 ==========

# 数据库模式: memory (内存) 或 database (数据库)
DB_MODE=memory

# SQLite 数据库文件路径
DB_FILE=data/restaurant_booking.db

# PostgreSQL 配置 (如果使用)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_DB=restaurant_booking

# ========== Agent 配置 ==========

# Agent 详细日志
AGENT_VERBOSE=true

# 最多保存对话数
MAX_CONVERSATION_HISTORY=50

# ========== 业务配置 ==========

# 餐厅营业时间
BUSINESS_HOURS_START=11:00
BUSINESS_HOURS_END=22:00

# 最大提前预订天数
MAX_ADVANCE_BOOKING_DAYS=30

# 最大派对人数
MAX_PARTY_SIZE=20

# ========== 通知配置 ==========

# 发送确认消息
SEND_CONFIRMATION=true

# 发送提醒消息
SEND_REMINDERS=false

# 提醒提前小时数
REMINDER_HOURS_BEFORE=24

# ========== 开发配置 ==========

# 开发模式
DEBUG=true

# CORS 允许来源
CORS_ORIGINS=*

# ========== 特性开关 ==========

# 多轮对话
ENABLE_MULTI_TURN=true

# 用户反馈学习
ENABLE_LEARNING=false

# 用户偏好记忆
ENABLE_USER_MEMORY=false

# 推荐引擎
ENABLE_RECOMMENDATIONS=false

# ========== 备注 ==========
# 1. 复制 .env.example to .env
# 2. 填入您的 API Keys
# 3. 程序会自动加载此文件
# 4. 不要在版本控制中提交此文件！
