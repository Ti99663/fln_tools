# ============ Ollama 配置 ============
# OLLAMA_MODELS=d:\ollama_models
# OLLAMA_HOME=d:\ollama

# ============ Anthropic 配置 ============
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ============ DeepSeek 配置 ============
# DEEPSEEK_API_KEY=your-deepseek-api-key

# ============ SSRAI 配置（GPT-4o 等）============
# 复制此文件为 .env，然后填写你的 SSRAI 信息
SSRAI_API_ENDPOINT=https://your-ssrai-endpoint.com/v1
SSRAI_API_KEY=your-ssrai-api-key
SSRAI_MODEL=gpt-4o
