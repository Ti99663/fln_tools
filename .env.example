# LLM API Key 配置
# 根据选择的 LLM 方案填写相应的 API Key

# Anthropic Claude API Key
# 获取地址: https://console.anthropic.com
ANTHROPIC_API_KEY=

# DeepSeek API Key
# 获取地址: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Ollama 本地配置 (不需要外部 API Key)
# 启动命令: ollama serve
# 模型下载: ollama pull llama2-chinese
OLLAMA_HOST=http://localhost:11434